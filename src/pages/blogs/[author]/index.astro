---
// src/pages/blogs/[author]/index.astro
import { getCollection } from 'astro:content';
import '../../../../src/styles/layout.css'; 

export async function getStaticPaths() {
  const allBlogs = await getCollection('blogs');
  const uniqueAuthors = [...new Set(allBlogs.map((post) => post.data.author))];

  return uniqueAuthors.map((author) => {
    const authorPosts = allBlogs.filter((post) => post.data.author === author);
    
    // Sort posts chronologically
    authorPosts.sort((a, b) => b.id.localeCompare(a.id));

    return {
      params: { author: author },
      props: { posts: authorPosts }, 
    };
  });
}

const { author } = Astro.params;
const { posts } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{`${author}'s Passages`}</title>
    
    <link id="theme-css" rel="stylesheet" href="/styles/github-modified.css" />
  </head>
  <body>
    <nav class="top-bar">
      <div class="nav-links">
        <a href="/">Home</a>
        <a href={`/blogs/${author}`}>{author}'s Posts</a>
      </div>
      <button id="theme-toggle" aria-label="Toggle Theme">🌓 Toggle Theme</button>
    </nav>

    <div class="layout-container" style="justify-content: center;">
      <main id="write" class="main-content" style="max-width: 800px;">
        <header>
          <h1>Passages by {author}</h1>
          <p>Total posts: {posts.length}</p>
        </header>

        <ul class="blog-list">
          {posts.map((post) => (
            <li>
              <a href={`/blogs/${author}/${post.id}`} style="font-size: 1.2rem; font-weight: bold;">{post.data.title}</a>
              <div class="meta" style="color: var(--text-color3, #666); font-size: 0.9rem;">Post ID: {post.id}</div>
            </li>
          ))}
        </ul>
      </main>
    </div>

    <script is:inline>
      const themeBtn = document.getElementById('theme-toggle');
      const themeLink = document.getElementById('theme-css');
      
      const savedTheme = localStorage.getItem('theme') || 'light';
      if (savedTheme === 'dark') {
        themeLink.href = '/styles/onedark-modified.css';
      }

      themeBtn.addEventListener('click', () => {
        const isDark = themeLink.href.includes('onedark');
        const newTheme = isDark ? 'light' : 'dark';
        
        themeLink.href = isDark 
          ? '/styles/github-modified.css' 
          : '/styles/onedark-modified.css';
          
        localStorage.setItem('theme', newTheme);
      });
    </script>
  </body>
</html>